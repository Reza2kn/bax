# Local dev: leave DATABASE_URL unset (or `file:./var/dev.sqlite`) to use SQLite.
# Production: set DATABASE_URL to a Postgres connection string (e.g. Neon).
#
# Examples:
#   DATABASE_URL=file:./var/dev.sqlite
#   DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/bax?sslmode=require

DATABASE_URL=

# Public site origin used for absolute links / OG tags. No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
